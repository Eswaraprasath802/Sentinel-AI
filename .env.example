# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key        # https://aistudio.google.com/app/apikey (free)

# ── Email alerts ────────────────────────────────────────────────────────────────
SENTINEL_EMAIL_TO=you@example.com
SENTINEL_EMAIL_FROM=alerts@gmail.com
SENTINEL_SMTP_USER=alerts@gmail.com
SENTINEL_SMTP_PASS=your_gmail_app_password  # gmail → Security → App Passwords

# ── WhatsApp alerts (Twilio — free sandbox) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # twilio.com → Console
TWILIO_AUTH_TOKEN=your_auth_token
SENTINEL_WHATSAPP_TO=whatsapp:+919876543210            # your number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886             # Twilio sandbox number

# ── Elasticsearch (optional) ────────────────────────────────────────────────────
ELASTIC_URL=https://your-deployment.es.io
ELASTIC_PASSWORD=your_elastic_password
